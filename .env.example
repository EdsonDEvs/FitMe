NEXT_PUBLIC_SUPABASE_URL="https://SEU_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="SUA_ANON_KEY"

# Use com cuidado: esta chave deve ficar apenas no backend (service role).
SUPABASE_SERVICE_ROLE_KEY="SUA_SERVICE_ROLE_KEY"

# Bucket do Supabase Storage onde as imagens serão salvas.
# Recomendo criar um bucket público (ou ajustar para URL assinada).
SUPABASE_STORAGE_BUCKET="refeicoes-imagens"

# API Key do Google Gemini.
GEMINI_API_KEY="SUA_GEMINI_API_KEY"

